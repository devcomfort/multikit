{
  "name": "structkit",
  "version": "2.0.0",
  "description": "Project structure governance, architecture analysis, and enforcement — directory roles, naming conventions, deployment patterns, architecture patterns, design recommendations, and CI validation",
  "agents": [
    "structkit.governance.agent.md",
    "structkit.analyze.agent.md",
    "structkit.fix.agent.md",
    "structkit.help.agent.md"
  ],
  "prompts": [
    "structkit.governance.prompt.md",
    "structkit.analyze.prompt.md",
    "structkit.fix.prompt.md",
    "structkit.help.prompt.md"
  ],
  "templates": [
    {
      "agent": "structkit.governance",
      "src": "structure-governance.template.md",
      "dest": ".github/structure-governance.md",
      "overwrite": false
    }
  ]
}
